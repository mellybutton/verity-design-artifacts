const rendered = new Set();

function show(id, el) {
  document.querySelectorAll('.diagram-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  const panel = document.getElementById('panel-' + id);
  panel.classList.add('active');
  el.classList.add('active');
  const [title, badge] = titles[id];
  document.getElementById('topbar-title').textContent = title;
  document.getElementById('topbar-badge').textContent = badge;
  // Lazy render mermaid diagram on first view
  if (!rendered.has(id)) {
    rendered.add(id);
    const el2 = panel.querySelector('.mermaid');
    if (el2) mermaid.init(undefined, el2);
  }
}

// Render first panel on load
window.addEventListener('load', function() {
  const first = document.querySelector('.diagram-panel.active .mermaid');
  if (first) {
    rendered.add('jordan-capture');
    mermaid.init(undefined, first);
  }
});
