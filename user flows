<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --indigo: #4752F5;
    --page-bg: #0B0C10;
    --surface: #12141A;
    --border: #1E2028;
    --text: #ECEDF2;
    --muted: #4A5369;
    --font-sans: 'DM Sans', system-ui, sans-serif;
    --font-display: 'Fraunces', Georgia, serif;
    --font-mono: 'DM Mono', monospace;
  }
  html, body { height: 100%; background: var(--page-bg); color: var(--text); font-family: var(--font-sans); }

.shell { display: flex; height: 100vh; }

/* Sidebar */
.sidebar {
width: 240px; flex-shrink: 0;
background: #0D0F14;
border-right: 1px solid var(–border);
display: flex; flex-direction: column;
overflow-y: auto;
}
.sidebar-header {
padding: 24px 20px 16px;
border-bottom: 1px solid var(–border);
}
.sidebar-eyebrow {
font-family: var(–font-mono);
font-size: 9px; letter-spacing: .1em; text-transform: uppercase;
color: var(–indigo); margin-bottom: 6px;
}
.sidebar-title {
font-family: var(–font-display);
font-style: italic; font-weight: 300;
font-size: 17px; color: var(–text); line-height: 1.3;
}
.sidebar-meta { font-size: 11px; color: var(–muted); margin-top: 6px; }
.sidebar-nav { padding: 12px 0; flex: 1; }
.nav-section-label {
font-family: var(–font-mono);
font-size: 9px; letter-spacing: .08em; text-transform: uppercase;
color: var(–muted); padding: 8px 20px 4px;
}
.nav-item {
display: flex; align-items: center; gap: 8px;
padding: 8px 20px; font-size: 13px; font-weight: 500;
color: #6B7280; cursor: pointer;
border-left: 2px solid transparent;
transition: all .12s;
}
.nav-item:hover { color: var(–text); background: rgba(255,255,255,.03); }
.nav-item.active { color: var(–text); border-left-color: var(–indigo); background: rgba(71,82,245,.08); }
.nav-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }

/* Main */
.main { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
.topbar {
padding: 16px 32px;
border-bottom: 1px solid var(–border);
display: flex; align-items: center; gap: 12px;
background: var(–page-bg);
}
.diagram-title { font-size: 16px; font-weight: 600; color: var(–text); }
.diagram-badge {
font-family: var(–font-mono); font-size: 10px;
padding: 2px 8px; border-radius: 4px;
background: rgba(71,82,245,.15); color: #818CF8;
}
.content { flex: 1; overflow-y: auto; padding: 32px; }

.diagram-panel { display: none; }
.diagram-panel.active { display: block; }

.diagram-desc {
font-size: 13px; color: var(–muted);
line-height: 1.6; margin-bottom: 24px;
max-width: 680px;
}
.diagram-desc strong { color: #9CA3AF; }

.mermaid-wrap {
background: var(–surface);
border: 1px solid var(–border);
border-radius: 10px;
padding: 32px;
overflow-x: auto;
}
.mermaid { display: flex; justify-content: center; }

/* Legend */
.legend {
display: flex; gap: 16px; flex-wrap: wrap;
margin-top: 20px;
}
.legend-item {
display: flex; align-items: center; gap: 6px;
font-size: 11px; color: var(–muted);
}
.legend-dot { width: 10px; height: 10px; border-radius: 3px; flex-shrink: 0; }
</style>

</head>
